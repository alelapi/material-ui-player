{
  "compilerOptions": {
    "target": "es2015",
    "module": "commonjs",
    "jsx": "react",
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "sourceMap": true,
    "rootDir": "./src",
    "outDir": "dist",
    "noImplicitAny": false,
    "lib": [
      "esnext",
      "dom"
    ],
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "src/stories"],
}
